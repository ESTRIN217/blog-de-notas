{
  "name": "Blog-de-notas",
  "image": "://mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    },
    "ghcr.io/casl0/devcontainer-features/android-sdk:1": {},
    "ghcr.io/devcontainers-community/templates/dart:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code"
      ]
    }
  },
  "remoteUser": "vscode",
  "overrideCommand": false
}
